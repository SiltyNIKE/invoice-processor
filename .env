# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ─── Google Service Account ───────────────────────────────────────────────────
# Path to the downloaded service account JSON key file
GOOGLE_CREDENTIALS_FILE=credentials.json

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<ID>/edit
SPREADSHEET_ID=YOUR_SPREADSHEET_ID

# ─── Google Drive Folder IDs ──────────────────────────────────────────────────
FOLDER_TO_PROCESS=YOUR_FOLDER_TO_PROCESS_ID
FOLDER_EXTRACTED=YOUR_FOLDER_EXTRACTED_ID
FOLDER_ERRORS=YOUR_FOLDER_ERRORS_ID

# ─── Polling interval (seconds) ──────────────────────────────────────────────
POLL_INTERVAL=30
