# Gemini API key
GEMINI_API_KEY=your_value_here

# Gemini model name
GEMINI_MODEL=gemini-2.5-flash

# Path to Google service account credentials JSON
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Sheets spreadsheet ID
SPREADSHEET_ID=your_value_here

# Google Drive folder ID: source folder to monitor
FOLDER_TO_PROCESS=your_value_here

# Google Drive folder ID: extracted invoices
FOLDER_EXTRACTED=your_value_here

# Google Drive folder ID: error invoices
FOLDER_ERRORS=your_value_here

# Google Drive folder ID: closed invoices (optional)
FOLDER_CLOSED=your_value_here

# Google Drive folder ID: quarantine invoices (optional)
FOLDER_QUARANTINE=your_value_here

# Poll interval in seconds
POLL_INTERVAL=30
